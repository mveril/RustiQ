{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "env": {"RUST_BACKTRACE":"1"},
      "name": "Debug executable 'RustiQ'",
      "cargo": {
        "args": [
          "build",
          "--bin=RustiQ",
          "--package=RustiQ",
        ],
        "filter": {
          "name": "RustiQ",
          "kind": "bin"
        }
      },
      "args": ["run", "samples/calculation.toml"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug unit tests in executable 'RustiQ'",
      "cargo": {
        "args": [
          "test",
          "--no-run",
          "--bin=RustiQ",
          "--package=RustiQ",
        ],
        "filter": {
          "name": "RustiQ",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  ]
}