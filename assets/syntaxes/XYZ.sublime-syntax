%YAML 1.2
---
name: XYZ Molecule
file_extensions:
  - xyz
scope: source.xyz-molecule

contexts:
  main:
    - match: '^\s*\d+\s*$'
      scope: constant.numeric.atom-count.xyz

    - match: '^\s*([A-Z][a-z]?|\d{1,3})(?=\s+)'
      captures:
        1: entity.name.atom.xyz

    - match: '[+-]?(?:\d+\.\d*|\.\d+|\d+)(?:[eE][+-]?\d+)?'
      scope: constant.numeric.coordinate.xyz
